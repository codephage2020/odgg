-- ETL generated by ODGG for business process: {{ model.business_process }}
-- Mode: {{ mode }}

{% for dim in model.dimensions %}
{% if not dim.is_degenerate %}
-- Load dimension: {{ dim.name }}
{% if mode == "full" %}
TRUNCATE TABLE {{ schema | quote_id }}.{{ dim.name | quote_id }};

INSERT INTO {{ schema | quote_id }}.{{ dim.name | quote_id }} (
    {% for col in dim.columns %}
    {{ col | quote_id }}{% if not loop.last %},{% endif %}
    {% endfor %}
    {% if dim.columns %},{% endif %}
    _source_id
)
SELECT
    {% for col in dim.columns %}
    {{ col | quote_id }}{% if not loop.last %},{% endif %}
    {% endfor %}
    {% if dim.columns %},{% endif %}
    {{ dim.natural_key | quote_id }}::TEXT as _source_id
FROM {{ source_schema | quote_id }}.{{ dim.source_table | quote_id }};
{% else %}
-- Incremental: MERGE/UPSERT dimension
INSERT INTO {{ schema | quote_id }}.{{ dim.name | quote_id }} (
    {% for col in dim.columns %}
    {{ col | quote_id }}{% if not loop.last %},{% endif %}
    {% endfor %}
    {% if dim.columns %},{% endif %}
    _source_id
)
SELECT
    {% for col in dim.columns %}
    s.{{ col | quote_id }}{% if not loop.last %},{% endif %}
    {% endfor %}
    {% if dim.columns %},{% endif %}
    s.{{ dim.natural_key | quote_id }}::TEXT as _source_id
FROM {{ source_schema | quote_id }}.{{ dim.source_table | quote_id }} s
ON CONFLICT (_source_id) DO UPDATE SET
    {% for col in dim.columns %}
    {{ col | quote_id }} = EXCLUDED.{{ col | quote_id }}{% if not loop.last %},{% endif %}
    {% endfor %};
{% endif %}

{% endif %}
{% endfor %}

-- Load fact table: {{ model.fact_table.name }}
{% if mode == "full" %}
TRUNCATE TABLE {{ schema | quote_id }}.{{ model.fact_table.name | quote_id }};
{% endif %}

INSERT INTO {{ schema | quote_id }}.{{ model.fact_table.name | quote_id }} (
    {% for dk in model.fact_table.dimension_keys %}
    {{ dk | quote_id }},
    {% endfor %}
    {% for dd in model.fact_table.degenerate_dimensions %}
    {{ dd | quote_id }},
    {% endfor %}
    {% for measure in model.fact_table.measures %}
    {{ measure.name | quote_id }}{% if not loop.last %},{% endif %}
    {% endfor %}
)
SELECT
    {% for dk in model.fact_table.dimension_keys %}
    d{{ loop.index0 }}.{{ model.dimensions[loop.index0].name }}_key,
    {% endfor %}
    {% for dd in model.fact_table.degenerate_dimensions %}
    src.{{ dd | quote_id }},
    {% endfor %}
    {% for measure in model.fact_table.measures %}
    src.{{ measure.source_column | quote_id }}{% if not loop.last %},{% endif %}
    {% endfor %}
FROM {{ source_schema | quote_id }}.{{ model.fact_table.source_tables[0] | quote_id }} src
{% for dim in model.dimensions %}
{% if not dim.is_degenerate %}
LEFT JOIN {{ schema | quote_id }}.{{ dim.name | quote_id }} d{{ loop.index0 }}
    ON src.{{ dim.natural_key | quote_id }}::TEXT = d{{ loop.index0 }}._source_id
{% endif %}
{% endfor %}
;
