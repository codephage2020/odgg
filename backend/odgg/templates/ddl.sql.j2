-- DDL generated by ODGG for business process: {{ model.business_process }}
-- Generated dimensional model version: {{ model.version }}

CREATE SCHEMA IF NOT EXISTS {{ schema | quote_id }};

{% for dim in model.dimensions %}
{% if not dim.is_degenerate %}
-- Dimension: {{ dim.name }}
-- Source: {{ dim.source_table }}
-- {{ dim.description }}
CREATE TABLE IF NOT EXISTS {{ schema | quote_id }}.{{ dim.name | quote_id }} (
    {{ dim.name }}_key SERIAL PRIMARY KEY,
    {% for col in dim.columns %}
    {{ col | quote_id }} TEXT{% if not loop.last %},{% endif %}
    {% endfor %}
    {% if dim.columns %},{% endif %}
    _source_id TEXT,
    _loaded_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

{% endif %}
{% endfor %}

-- Fact table: {{ model.fact_table.name }}
-- Grain: {{ model.fact_table.grain_description }}
CREATE TABLE IF NOT EXISTS {{ schema | quote_id }}.{{ model.fact_table.name | quote_id }} (
    {{ model.fact_table.name }}_key SERIAL PRIMARY KEY,
    {% for dk in model.fact_table.dimension_keys %}
    {{ dk | quote_id }} INTEGER REFERENCES {{ schema | quote_id }}.{{ model.dimensions[loop.index0].name | quote_id }}({{ model.dimensions[loop.index0].name }}_key),
    {% endfor %}
    {% for dd in model.fact_table.degenerate_dimensions %}
    {{ dd | quote_id }} TEXT,
    {% endfor %}
    {% for measure in model.fact_table.measures %}
    {{ measure.name | quote_id }} {{ measure.data_type }}{% if not loop.last %},{% endif %}
    {% endfor %}
    ,
    _loaded_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);
