# ODGG Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ─── LLM Provider ───────────────────────────────────────
# Supported: openai | ollama | anthropic
ODGG_LLM_PROVIDER=openai
ODGG_LLM_MODEL=gpt-4o
ODGG_LLM_API_KEY=sk-...

# For Ollama (zero-cost local):
# ODGG_LLM_PROVIDER=ollama
# ODGG_LLM_MODEL=llama3.1
# ODGG_LLM_BASE_URL=http://localhost:11434

# For Anthropic:
# ODGG_LLM_PROVIDER=anthropic
# ODGG_LLM_MODEL=claude-sonnet-4-20250514
# ODGG_LLM_API_KEY=sk-ant-...

# ─── Optional ───────────────────────────────────────────
# ODGG_DEBUG=true
# ODGG_LLM_TIMEOUT=30
